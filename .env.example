# =============================================================================
# GoACBr API — Environment Variables
# =============================================================================

# --- Server ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_READ_TIMEOUT=15s
SERVER_WRITE_TIMEOUT=15s
SERVER_SHUTDOWN_TIMEOUT=30s

# --- Database (PostgreSQL) ---
DB_HOST=postgres
DB_PORT=5432
DB_USER=goacbr
DB_PASSWORD=changeme_db_password
DB_NAME=goacbr
DB_SSL_MODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=5m

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# --- JWT ---
JWT_SECRET=changeme_jwt_secret_at_least_32_chars_long
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=168h

# --- Encryption (AES-256-GCM for certificates) ---
ENCRYPTION_KEY=changeme_32_byte_hex_encryption_key

# --- Backblaze B2 (S3-compatible) ---
B2_KEY_ID=your_b2_key_id
B2_APP_KEY=your_b2_application_key
B2_BUCKET_NAME=goacbr-storage
B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com
B2_REGION=us-west-004

# --- CNPJ.ws API ---
CNPJWS_API_URL=https://publica.cnpj.ws/cnpj
CNPJWS_API_TOKEN=

# --- ACBrLib ---
ACBR_LIB_PATH=/app/lib/libacbrnfe64.so
ACBR_SCHEMAS_PATH=/app/data/Schemas/NFe
ACBR_LOG_PATH=/app/logs
ACBR_LOG_LEVEL=4

# --- Rate Limiting ---
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10

# --- Logging ---
LOG_LEVEL=info
LOG_FORMAT=json
